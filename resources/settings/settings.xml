<settings xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://developer.garmin.com/downloads/connect-iq/resources.xsd">

    <!-- ── GPS Mode ─────────────────────────────────────────────── -->
    <setting propertyKey="@Properties.GpsMode" title="@Strings.SettingGpsModeTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.SettingGpsModeGps</listEntry>
            <listEntry value="1">@Strings.SettingGpsModeGpsGlonass</listEntry>
            <listEntry value="2">@Strings.SettingGpsModeAllSat</listEntry>
            <listEntry value="3">@Strings.SettingGpsModeAviation</listEntry>
        </settingConfig>
    </setting>

    <!-- ── Timer Interval ────────────────────────────────────────── -->
    <setting propertyKey="@Properties.TimerInterval" title="@Strings.SettingTimerTitle">
        <settingConfig type="numeric" min="0" max="30"/>
    </setting>

    <!-- ── Takeoff Speed ─────────────────────────────────────────── -->
    <setting propertyKey="@Properties.TakeoffSpeed" title="@Strings.SettingTakeoffTitle">
        <settingConfig type="numeric" min="0" max="100"/>
    </setting>

    <!-- Transition Altitude -->
    <setting propertyKey="@Properties.TransitionAltitudeFt" title="@Strings.SettingTransitionTitle">
        <settingConfig type="numeric" min="0" max="20000"/>
    </setting>

    <!-- Heart-Rate Alert -->
    <setting propertyKey="@Properties.HrThreshold" title="@Strings.SettingHrTitle">
        <settingConfig type="numeric" min="0" max="220"/>
    </setting>

    <!-- Fuel Check Interval -->
    <setting propertyKey="@Properties.FuelCheckInterval" title="@Strings.SettingFuelTitle">
        <settingConfig type="numeric" min="0" max="120"/>
    </setting>

    <!-- ── Companion App Toggle ───────────────────────────────────── -->
    <setting propertyKey="@Properties.UseCompanionApp" title="Use Companion App">
        <settingConfig type="list">
            <listEntry value="0">No</listEntry>
            <listEntry value="1">Yes</listEntry>
        </settingConfig>
    </setting>

    <setting propertyKey="@Properties.BezelUseAtlas" title="@Strings.SettingBezelAtlasTitle">
        <settingConfig type="list">
            <listEntry value="0">Vector</listEntry>
            <listEntry value="1">Atlas</listEntry>
        </settingConfig>
    </setting>

    <setting propertyKey="@Properties.BezelFontScale" title="@Strings.SettingBezelFontScaleTitle">
        <settingConfig type="numeric" min="70" max="130"/>
    </setting>

    <setting propertyKey="@Properties.BezelContrast" title="@Strings.SettingBezelContrastTitle">
        <settingConfig type="numeric" min="50" max="100"/>
    </setting>

    <setting propertyKey="@Properties.BezelOffsetHDG" title="@Strings.SettingBezelOffsetHDGTitle">
        <settingConfig type="numeric" min="-20" max="20"/>
    </setting>

    <setting propertyKey="@Properties.BezelOffsetGS" title="@Strings.SettingBezelOffsetGSTitle">
        <settingConfig type="numeric" min="-20" max="20"/>
    </setting>

    <setting propertyKey="@Properties.BezelOffsetALT" title="@Strings.SettingBezelOffsetALTTitle">
        <settingConfig type="numeric" min="-20" max="20"/>
    </setting>

    <setting propertyKey="@Properties.BezelOffsetQNH" title="@Strings.SettingBezelOffsetQNHTitle">
        <settingConfig type="numeric" min="-20" max="20"/>
    </setting>

</settings>
